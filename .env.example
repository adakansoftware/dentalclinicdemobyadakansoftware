# Database (Neon PostgreSQL)
# Local Windows note: runtime adds sslaccept=accept_invalid_certs and disables strict channel binding in non-production when needed.
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/dental?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/dental?sslmode=require"

# Admin session secret (min 32 chars, generate with: openssl rand -hex 32)
SESSION_SECRET="your-super-secret-session-key-min-32-chars-here"

# Seeded admin user
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-admin-password"
ADMIN_NAME="Clinic Admin"

# SMS (Netgsm)
SMS_ENABLED="false"
NETGSM_USERNAME="your-netgsm-username"
NETGSM_PASSWORD="your-netgsm-password"
NETGSM_HEADER="KLINIK"

# Vercel Cron secret (set same value in vercel.json)
CRON_SECRET="your-cron-secret-here"

# App URL
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Optional legacy alias
NEXT_PUBLIC_SITE_URL="https://your-domain.com"
NEXTAUTH_URL="https://your-domain.com"
VERCEL_PROJECT_PRODUCTION_URL="your-project.vercel.app"

# Google Places reviews
GOOGLE_PLACES_API_KEY="your-google-places-api-key"
GOOGLE_PLACE_ID="your-google-place-id"

# Optional bot protection (set both values together or leave both empty)
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your-turnstile-site-key"
